{
  "title": "Task Tracker API — Performance Dashboard",
  "uid": "task-tracker-api-otel",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 5,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Total Request Rate (req/s) with Trace Exemplars",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{exported_job=~\"TaskTrackerAPI|task-tracker-api\"}[1m]))",
          "legendFormat": "Total Throughput",
          "refId": "A"
        }
      ],
      "options": {
        "exemplars": {
          "enable": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 }
    }
  ]
}